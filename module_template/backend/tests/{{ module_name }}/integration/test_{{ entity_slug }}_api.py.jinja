from flask.testing import FlaskClient


def test_create_list_and_get_{{ module_name }}(client: FlaskClient) -> None:
    create_response = client.post("/{{ module_name }}", json={"name": "Example"})
    assert create_response.status_code == 201
    created_id = create_response.get_json()["id"]

    list_response = client.get("/{{ module_name }}")
    assert list_response.status_code == 200
    assert len(list_response.get_json()) == 1

    get_response = client.get(f"/{{ module_name }}/{created_id}")
    assert get_response.status_code == 200
    assert get_response.get_json()["id"] == created_id


def test_get_{{ module_name }}_returns_404_when_not_found(client: FlaskClient) -> None:
    response = client.get("/{{ module_name }}/00000000-0000-0000-0000-000000000000")
    assert response.status_code == 404


def test_create_{{ module_name }}_returns_400_when_name_is_missing(client: FlaskClient) -> None:
    response = client.post("/{{ module_name }}", json={})
    assert response.status_code == 400
