[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ project_description }}"
authors = [{ name = "{{ author_name }}", email = "{{ author_email }}" }]
requires-python = ">={{ python_version }}"
dependencies = [
    "flask>=3.0",
    "flask-cors>=5.0",
    "python-dotenv>=1.0",
    "gunicorn>=23.0",
]

[dependency-groups]
dev = [
    "ruff>=0.6",
    "pyright>=1.1",
    "pytest>=8.3",
    "pytest-cov>=5.0",
    "import-linter>=2.1",
    "pre-commit>=3.8",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]

[tool.ruff]
target-version = "py{{ python_version.replace('.', '') }}"
line-length = 100
src = ["src", "tests"]

[tool.ruff.lint]
select = [
    "E",   # pycodestyle
    "F",   # pyflakes
    "I",   # isort
    "UP",  # pyupgrade
    "B",   # flake8-bugbear
    "SIM", # flake8-simplify
    "ARG", # flake8-unused-arguments
    "C4",  # flake8-comprehensions
    "PT",  # flake8-pytest-style
]
ignore = ["E501"]

[tool.ruff.lint.isort]
known-first-party = ["{{ package_name }}"]

[tool.ruff.format]
quote-style = "double"

[tool.pyright]
include = ["src", "tests"]
venvPath = "."
venv = ".venv"
typeCheckingMode = "standard"
reportMissingImports = true

[tool.pytest.ini_options]
testpaths = ["tests"]
pythonpath = ["src"]
addopts = "-ra"

[tool.coverage.run]
source = ["src/{{ package_name }}"]
branch = true

[tool.coverage.report]
show_missing = true
fail_under = {{ min_test_coverage }}
exclude_lines = [
    "pragma: no cover",
    "if TYPE_CHECKING:",
    "raise NotImplementedError",
]

[tool.importlinter]
root_package = "{{ package_name }}"

# Cada módulo de negócio (bounded context) sob src/{{ package_name }}/ tem suas próprias
# camadas internas (domain/application/infrastructure/interfaces). Este contrato vale para
# TODOS eles automaticamente — inclusive módulos criados depois com `just new-module` — sem
# precisar editar este arquivo. Camadas são "opcionais" (entre parênteses) porque um container
# como "shared" não tem essa subestrutura.
[[tool.importlinter.contracts]]
name = "Cada módulo respeita suas próprias camadas (Clean Architecture)"
type = "layers"
containers = ["{{ package_name }}.*"]
layers = [
    "(interfaces)",
    "(infrastructure)",
    "(application)",
    "(domain)",
]

[[tool.importlinter.contracts]]
name = "shared não depende de nenhum módulo de negócio"
type = "forbidden"
source_modules = ["{{ package_name }}.shared"]
forbidden_modules = ["{{ package_name }}.*"]
