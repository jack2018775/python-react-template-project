import { render, screen, waitFor } from "@testing-library/react";
import { afterEach, describe, expect, it, vi } from "vitest";

import App from "./App";

describe("App", () => {
  afterEach(() => {
    vi.unstubAllGlobals();
  });

  it("renders the project name", () => {
    vi.stubGlobal(
      "fetch",
      vi.fn().mockResolvedValue({ json: () => Promise.resolve({ status: "ok" }) }),
    );

    render(<App />);

    expect(screen.getByText("{{ project_name }}")).toBeInTheDocument();
  });

  it("shows the backend status once the health check resolves", async () => {
    vi.stubGlobal(
      "fetch",
      vi.fn().mockResolvedValue({ json: () => Promise.resolve({ status: "ok" }) }),
    );

    render(<App />);

    await waitFor(() => expect(screen.getByText("ok")).toBeInTheDocument());
  });

  it("shows 'unreachable' when the backend can't be reached", async () => {
    vi.stubGlobal("fetch", vi.fn().mockRejectedValue(new Error("network error")));

    render(<App />);

    await waitFor(() => expect(screen.getByText("unreachable")).toBeInTheDocument());
  });
});
